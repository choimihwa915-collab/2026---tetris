<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Modern Tetris with Gemini AI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            --bg-color: #0f172a;
            --grid-color: #1e293b;
        }
        body {
            background-color: var(--bg-color);
            color: white;
            font-family: 'Pretendard', system-ui, -apple-system, sans-serif;
            touch-action: none;
            overflow: hidden;
        }
        #game-container {
            position: relative;
            max-width: 100vw;
            max-height: 100vh;
        }
        canvas {
            border: 4px solid #334155;
            border-radius: 8px;
            background-color: rgba(0, 0, 0, 0.3);
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.5);
        }
        .controls-btn {
            user-select: none;
            touch-action: manipulation;
        }
        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }
        .game-over-anim {
            animation: pulse 2s infinite;
        }
        .loading-spinner {
            border: 3px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top: 3px solid #3b82f6;
            width: 24px;
            height: 24px;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body class="flex flex-col items-center justify-center min-h-screen p-4">

    <div id="game-container" class="flex flex-col md:flex-row gap-6 items-center">
        <!-- 왼쪽: 메인 게임판 -->
        <div class="relative">
            <canvas id="tetris"></canvas>
            
            <!-- 게임 오버 오버레이 -->
            <div id="game-over" class="hidden absolute inset-0 bg-black/90 flex flex-col items-center justify-center rounded-lg z-20 text-center p-6 overflow-y-auto">
                <h2 class="text-4xl font-bold text-red-500 mb-2">GAME OVER</h2>
                <div class="mb-4">
                    <p id="final-score" class="text-xl font-bold">최종 점수: 0</p>
                    <p id="final-stats" class="text-slate-400 text-sm">레벨: 1 | 라인: 0</p>
                </div>

                <!-- Gemini AI 분석 섹션 -->
                <div id="ai-analysis-container" class="w-full bg-slate-800/50 rounded-lg p-4 mb-6 border border-blue-500/30">
                    <p class="text-blue-400 text-xs font-bold uppercase mb-2 flex items-center justify-center gap-1">
                        ✨ Gemini AI 전략 분석
                    </p>
                    <div id="ai-loading" class="flex flex-col items-center py-4">
                        <div class="loading-spinner mb-2"></div>
                        <p class="text-xs text-slate-400">AI가 당신의 플레이를 분석 중...</p>
                    </div>
                    <p id="ai-feedback" class="text-sm text-slate-200 leading-relaxed text-left hidden italic"></p>
                </div>

                <button onclick="resetGame()" class="bg-blue-600 hover:bg-blue-500 text-white px-8 py-3 rounded-full font-bold transition-all active:scale-95 shadow-lg shadow-blue-500/20">다시 시작</button>
            </div>

            <!-- 시작 화면 -->
            <div id="start-screen" class="absolute inset-0 bg-slate-900/90 flex flex-col items-center justify-center rounded-lg z-10 text-center p-4">
                <h1 class="text-5xl font-extrabold text-blue-400 mb-6 tracking-tighter">TETRIS</h1>
                <button onclick="startGame()" class="bg-blue-600 hover:bg-blue-500 text-white px-10 py-4 rounded-full font-bold text-xl transition-all active:scale-95 shadow-lg shadow-blue-500/20">게임 시작</button>
                <p class="mt-8 text-slate-400 text-sm">화살표 키 또는 화면 버튼으로 조작</p>
            </div>
        </div>

        <!-- 오른쪽: 정보창 -->
        <div class="flex flex-col gap-4 w-full md:w-48">
            <div class="bg-slate-800 p-4 rounded-xl border border-slate-700">
                <p class="text-slate-400 text-xs uppercase font-bold mb-1">다음 블록</p>
                <div class="flex justify-center bg-slate-900 rounded-lg p-2">
                    <canvas id="next" width="80" height="80"></canvas>
                </div>
            </div>

            <div class="bg-slate-800 p-4 rounded-xl border border-slate-700 flex flex-col gap-2">
                <div>
                    <p class="text-slate-400 text-xs uppercase font-bold">점수</p>
                    <p id="score" class="text-2xl font-mono font-bold text-blue-400">0</p>
                </div>
                <div>
                    <p class="text-slate-400 text-xs uppercase font-bold">레벨</p>
                    <p id="level" class="text-2xl font-mono font-bold text-purple-400">1</p>
                </div>
                <div>
                    <p class="text-slate-400 text-xs uppercase font-bold">라인</p>
                    <p id="lines" class="text-2xl font-mono font-bold text-emerald-400">0</p>
                </div>
            </div>
        </div>
    </div>

    <!-- 모바일 컨트롤러 -->
    <div class="mt-8 grid grid-cols-3 gap-2 w-full max-w-[300px] md:hidden">
        <div></div>
        <button class="controls-btn bg-slate-700 p-4 rounded-lg flex justify-center items-center" onmousedown="handleControl('rotate')" ontouchstart="handleControl('rotate')">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
        </button>
        <div></div>
        <button class="controls-btn bg-slate-700 p-4 rounded-lg flex justify-center items-center" onmousedown="handleControl('left')" ontouchstart="handleControl('left')">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        </button>
        <button class="controls-btn bg-slate-700 p-4 rounded-lg flex justify-center items-center" onmousedown="handleControl('down')" ontouchstart="handleControl('down')">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <button class="controls-btn bg-slate-700 p-4 rounded-lg flex justify-center items-center" onmousedown="handleControl('right')" ontouchstart="handleControl('right')">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </button>
        <div></div>
        <button class="controls-btn col-span-1 bg-blue-700 p-4 rounded-lg flex justify-center items-center font-bold" onmousedown="handleControl('hard')" ontouchstart="handleControl('hard')">DROP</button>
        <div></div>
    </div>

    <script>
        // API 설정
        const apiKey = "";
        
        const canvas = document.getElementById('tetris');
        const context = canvas.getContext('2d');
        const nextCanvas = document.getElementById('next');
        const nextContext = nextCanvas.getContext('2d');

        const ROW = 20;
        const COL = 10;
        const SQ = 30;

        canvas.width = COL * SQ;
        canvas.height = ROW * SQ;

        const COLORS = [null, '#ef4444', '#22c55e', '#3b82f6', '#eab308', '#a855f7', '#f97316', '#06b6d4'];
        const PIECES = [
            null,
            [[1, 1, 0], [0, 1, 1], [0, 0, 0]],
            [[0, 2, 2], [2, 2, 0], [0, 0, 0]],
            [[0, 3, 0], [3, 3, 3], [0, 0, 0]],
            [[4, 4], [4, 4]],
            [[5, 0, 0], [5, 5, 5], [0, 0, 0]],
            [[0, 0, 6], [6, 6, 6], [0, 0, 0]],
            [[0, 0, 0, 0], [7, 7, 7, 7], [0, 0, 0, 0], [0, 0, 0, 0]]
        ];

        let board = createMatrix(COL, ROW);
        let score = 0;
        let lines = 0;
        let level = 1;
        let dropCounter = 0;
        let dropInterval = 1000;
        let lastTime = 0;
        let paused = true;

        const player = {
            pos: {x: 0, y: 0},
            matrix: null,
            next: null
        };

        // --- Gemini AI 통합 기능 ---

        /**
         * 지수 백오프를 이용한 Gemini API 호출 함수
         */
        async function fetchGeminiAnalysis(gameData) {
            const systemPrompt = "당신은 테트리스 게임 전략 전문가입니다. 사용자의 게임 결과를 바탕으로 칭찬과 함께 실력을 향상시킬 수 있는 짧고 임팩트 있는 조언을 한국어로 한 문장 또는 두 문장으로 제공하세요. 친근하면서도 전문적인 톤을 유지하세요.";
            const userQuery = `게임 결과 - 점수: ${gameData.score}, 도달 레벨: ${gameData.level}, 제거한 라인 수: ${gameData.lines}. 이 결과를 분석해서 피드백을 줘.`;

            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            
            const payload = {
                contents: [{ parts: [{ text: userQuery }] }],
                systemInstruction: { parts: [{ text: systemPrompt }] }
            };

            let delay = 1000;
            for (let i = 0; i < 5; i++) {
                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    
                    if (response.ok) {
                        const result = await response.json();
                        return result.candidates?.[0]?.content?.parts?.[0]?.text || "놀라운 플레이였어요! 다음 판은 더 높은 점수를 노려보세요.";
                    }
                } catch (error) {
                    // 오류 발생 시 다음 재시도로 넘어감
                }
                await new Promise(res => setTimeout(res, delay));
                delay *= 2;
            }
            return "플레이하시느라 수고하셨습니다! 당신의 실력은 계속 성장하고 있습니다.";
        }

        async function showAiAnalysis() {
            const loadingEl = document.getElementById('ai-loading');
            const feedbackEl = document.getElementById('ai-feedback');
            
            loadingEl.classList.remove('hidden');
            feedbackEl.classList.add('hidden');
            feedbackEl.innerText = "";

            const gameData = { score, level, lines };
            const feedback = await fetchGeminiAnalysis(gameData);
            
            loadingEl.classList.add('hidden');
            feedbackEl.innerText = feedback;
            feedbackEl.classList.remove('hidden');
        }

        // --- 게임 로직 ---

        function createMatrix(w, h) {
            const matrix = [];
            while (h--) matrix.push(new Array(w).fill(0));
            return matrix;
        }

        function draw() {
            context.fillStyle = '#0f172a';
            context.fillRect(0, 0, canvas.width, canvas.height);

            context.strokeStyle = 'rgba(255, 255, 255, 0.05)';
            for(let i=0; i<COL; i++) {
                context.beginPath();
                context.moveTo(i*SQ, 0);
                context.lineTo(i*SQ, canvas.height);
                context.stroke();
            }
            for(let i=0; i<ROW; i++) {
                context.beginPath();
                context.moveTo(0, i*SQ);
                context.lineTo(canvas.width, i*SQ);
                context.stroke();
            }

            drawMatrix(board, {x: 0, y: 0}, context);
            drawMatrix(player.matrix, player.pos, context);
            drawGhost();
            drawNext();
        }

        function drawMatrix(matrix, offset, ctx) {
            matrix.forEach((row, y) => {
                row.forEach((value, x) => {
                    if (value !== 0) {
                        const posX = (x + offset.x) * SQ;
                        const posY = (y + offset.y) * SQ;
                        ctx.fillStyle = COLORS[value];
                        ctx.fillRect(posX, posY, SQ, SQ);
                        ctx.strokeStyle = 'rgba(255,255,255,0.4)';
                        ctx.strokeRect(posX + 1, posY + 1, SQ - 2, SQ - 2);
                    }
                });
            });
        }

        function drawNext() {
            nextContext.fillStyle = '#0f172a';
            nextContext.fillRect(0, 0, nextCanvas.width, nextCanvas.height);
            const m = player.next;
            if (!m) return;
            const size = 20;
            const offX = (nextCanvas.width - m[0].length * size) / 2;
            const offY = (nextCanvas.height - m.length * size) / 2;
            m.forEach((row, y) => {
                row.forEach((value, x) => {
                    if (value !== 0) {
                        nextContext.fillStyle = COLORS[value];
                        nextContext.fillRect(offX + x * size, offY + y * size, size - 1, size - 1);
                    }
                });
            });
        }

        function drawGhost() {
            const ghost = { pos: {x: player.pos.x, y: player.pos.y}, matrix: player.matrix };
            while (!collide(board, ghost)) ghost.pos.y++;
            ghost.pos.y--;
            ghost.matrix.forEach((row, y) => {
                row.forEach((value, x) => {
                    if (value !== 0) {
                        context.strokeStyle = 'rgba(255, 255, 255, 0.2)';
                        context.strokeRect((x + ghost.pos.x) * SQ + 2, (y + ghost.pos.y) * SQ + 2, SQ - 4, SQ - 4);
                    }
                });
            });
        }

        function collide(board, player) {
            const [m, o] = [player.matrix, player.pos];
            for (let y = 0; y < m.length; ++y) {
                for (let x = 0; x < m[y].length; ++x) {
                    if (m[y][x] !== 0 && (board[y + o.y] && board[y + o.y][x + o.x]) !== 0) return true;
                }
            }
            return false;
        }

        function merge(board, player) {
            player.matrix.forEach((row, y) => {
                row.forEach((value, x) => {
                    if (value !== 0) board[y + player.pos.y][x + player.pos.x] = value;
                });
            });
        }

        function rotate(matrix, dir) {
            for (let y = 0; y < matrix.length; ++y) {
                for (let x = 0; x < y; ++x) [matrix[x][y], matrix[y][x]] = [matrix[y][x], matrix[x][y]];
            }
            dir > 0 ? matrix.forEach(row => row.reverse()) : matrix.reverse();
        }

        function playerDrop() {
            player.pos.y++;
            if (collide(board, player)) {
                player.pos.y--;
                merge(board, player);
                playerReset();
                arenaSweep();
                updateScore();
            }
            dropCounter = 0;
        }

        function playerMove(dir) {
            player.pos.x += dir;
            if (collide(board, player)) player.pos.x -= dir;
        }

        function playerRotate(dir) {
            const pos = player.pos.x;
            let offset = 1;
            rotate(player.matrix, dir);
            while (collide(board, player)) {
                player.pos.x += offset;
                offset = -(offset + (offset > 0 ? 1 : -1));
                if (offset > player.matrix[0].length) {
                    rotate(player.matrix, -dir);
                    player.pos.x = pos;
                    return;
                }
            }
        }

        function playerReset() {
            if (!player.next) player.next = PIECES[Math.floor(Math.random() * (PIECES.length - 1)) + 1];
            player.matrix = player.next;
            player.next = PIECES[Math.floor(Math.random() * (PIECES.length - 1)) + 1];
            player.pos.y = 0;
            player.pos.x = Math.floor(COL / 2) - Math.floor(player.matrix[0].length / 2);
            if (collide(board, player)) gameOver();
        }

        function arenaSweep() {
            let rowCount = 1;
            outer: for (let y = board.length - 1; y > 0; --y) {
                for (let x = 0; x < board[y].length; ++x) {
                    if (board[y][x] === 0) continue outer;
                }
                const row = board.splice(y, 1)[0].fill(0);
                board.unshift(row);
                ++y;
                score += rowCount * 10;
                rowCount *= 2;
                lines++;
                if (lines % 10 === 0) {
                    level++;
                    dropInterval = Math.max(100, 1000 - (level - 1) * 100);
                }
            }
        }

        function updateScore() {
            document.getElementById('score').innerText = score;
            document.getElementById('level').innerText = level;
            document.getElementById('lines').innerText = lines;
        }

        function gameOver() {
            paused = true;
            document.getElementById('final-score').innerText = `최종 점수: ${score}`;
            document.getElementById('final-stats').innerText = `레벨: ${level} | 라인: ${lines}`;
            document.getElementById('game-over').classList.remove('hidden');
            showAiAnalysis(); // Gemini AI 분석 시작
        }

        function resetGame() {
            board = createMatrix(COL, ROW);
            score = 0;
            lines = 0;
            level = 1;
            dropInterval = 1000;
            updateScore();
            document.getElementById('game-over').classList.add('hidden');
            playerReset();
            paused = false;
            requestAnimationFrame(update);
        }

        function startGame() {
            document.getElementById('start-screen').classList.add('hidden');
            resetGame();
        }

        function update(time = 0) {
            if (paused) return;
            const deltaTime = time - lastTime;
            lastTime = time;
            dropCounter += deltaTime;
            if (dropCounter > dropInterval) playerDrop();
            draw();
            requestAnimationFrame(update);
        }

        document.addEventListener('keydown', event => {
            if (paused) return;
            if (event.keyCode === 37) playerMove(-1);
            else if (event.keyCode === 39) playerMove(1);
            else if (event.keyCode === 40) playerDrop();
            else if (event.keyCode === 38) playerRotate(1);
            else if (event.keyCode === 32) {
                while (!collide(board, player)) player.pos.y++;
                player.pos.y--;
                merge(board, player);
                playerReset();
                arenaSweep();
                updateScore();
            }
        });

        function handleControl(action) {
            if (paused) return;
            switch(action) {
                case 'left': playerMove(-1); break;
                case 'right': playerMove(1); break;
                case 'down': playerDrop(); break;
                case 'rotate': playerRotate(1); break;
                case 'hard': 
                    while (!collide(board, player)) player.pos.y++;
                    player.pos.y--;
                    merge(board, player);
                    playerReset();
                    arenaSweep();
                    updateScore();
                    break;
            }
        }

        function resize() {
            const h = window.innerHeight;
            const w = window.innerWidth;
            if (w < 500) {
                const newSq = Math.min(w / 12, h / 25);
                canvas.width = COL * newSq;
                canvas.height = ROW * newSq;
            }
        }

        window.addEventListener('resize', resize);
        resize();
    </script>
</body>
</html>
